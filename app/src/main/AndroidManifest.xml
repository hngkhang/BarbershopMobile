<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <application
        android:name=".BarbershopApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Barbershop">
        <activity
            android:name=".util.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".util.ReviewActivity"
            android:exported="false" />
        <activity
            android:name=".util.AppointmentDetailActivity"
            android:exported="false" />
        <activity
            android:name=".util.AppointmentActivity"
            android:exported="false" />
        <activity
            android:name=".util.PaymentActivity"
            android:exported="false" />
        <activity
            android:name=".util.AIChatBookingActivity"
            android:exported="false" />
        <activity
            android:name=".util.BookingConfirmActivity"
            android:exported="false" />
        <activity
            android:name=".util.BookingActivity"
            android:exported="false" />
        <activity
            android:name=".util.BarberDetailActivity"
            android:exported="false" />
        <activity
            android:name=".util.BarberListActivity"
            android:exported="false" />
        <activity
            android:name=".util.ServiceListActivity"
            android:exported="false" />
        <activity
            android:name=".util.HomeActivity"
            android:exported="false" />
        <activity
            android:name=".util.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".util.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".util.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".util.MainActivity"
            android:exported="false" />
        <service
            android:name=".services.MakePaymentService"
            android:exported="false" />
        <receiver
            android:name=".receivers.AppointmentReminderReceiver"
            android:exported="false" />
    </application>

</manifest>
