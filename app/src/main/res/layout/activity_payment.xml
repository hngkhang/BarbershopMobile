<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/paymentRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:fitsSystemWindows="true"
    tools:context=".util.PaymentActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/paymentTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/space_16"
        android:paddingEnd="@dimen/screen_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_back"
            android:padding="@dimen/space_12"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textPaymentTitle"
            style="@style/TextAppearance_ArtBarbershop_CardTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/screen_payment_title"
            app:layout_constraintBottom_toBottomOf="@id/buttonBack"
            app:layout_constraintEnd_toStartOf="@id/buttonPaymentMore"
            app:layout_constraintStart_toEndOf="@id/buttonBack"
            app:layout_constraintTop_toTopOf="@id/buttonBack" />

        <ImageButton
            android:id="@+id/buttonPaymentMore"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_more_options"
            android:padding="@dimen/space_12"
            android:src="@drawable/ic_more_horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            style="@style/TextAppearance_ArtBarbershop_Caption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/payment_subtitle"
            app:layout_constraintEnd_toEndOf="@id/textPaymentTitle"
            app:layout_constraintStart_toStartOf="@id/textPaymentTitle"
            app:layout_constraintTop_toBottomOf="@id/textPaymentTitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/paymentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/screen_horizontal_padding"
        android:paddingEnd="@dimen/screen_horizontal_padding"
        android:paddingBottom="@dimen/space_16"
        app:layout_constraintBottom_toTopOf="@id/paymentActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/paymentTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget_ArtBarbershop_Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_16">

                    <TextView
                        android:id="@+id/textPaymentBarberInitial"
                        style="@style/TextAppearance_ArtBarbershop_CardTitle"
                        android:layout_width="@dimen/payment_summary_avatar_size"
                        android:layout_height="@dimen/payment_summary_avatar_size"
                        android:background="@drawable/bg_avatar_circle"
                        android:gravity="center"
                        android:textColor="@color/color_primary"
                        tools:text="M" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_12"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textPaymentBarber"
                            style="@style/TextAppearance_ArtBarbershop_CardTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="Michael" />

                        <TextView
                            android:id="@+id/textPaymentService"
                            style="@style/TextAppearance_ArtBarbershop_Caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="Haircut, Classic Cut" />

                        <TextView
                            android:id="@+id/textPaymentDate"
                            style="@style/TextAppearance_ArtBarbershop_Caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_6"
                            tools:text="Tomorrow, May 25, 2025" />

                        <TextView
                            android:id="@+id/textPaymentTime"
                            style="@style/TextAppearance_ArtBarbershop_Caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="2:00 PM - 45 min" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textPaymentAmount"
                            style="@style/TextAppearance_ArtBarbershop_SectionTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/color_text_primary"
                            tools:text="$25.00" />

                        <TextView
                            style="@style/TextAppearance_ArtBarbershop_Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/payment_total_amount"
                            android:textColor="@color/color_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/TextAppearance_ArtBarbershop_Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:gravity="center"
                android:text="@string/payment_scan_to_pay"
                android:textColor="@color/color_text_primary"
                android:textStyle="bold" />

            <TextView
                style="@style/TextAppearance_ArtBarbershop_Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/payment_scan_instruction" />

            <FrameLayout
                android:id="@+id/paymentQrPlaceholder"
                android:layout_width="@dimen/qr_code_size"
                android:layout_height="@dimen/qr_code_size"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_12"
                android:background="@drawable/bg_qr_placeholder"
                android:contentDescription="@string/payment_qr_content_description"
                android:padding="@dimen/space_16">

                <FrameLayout
                    android:layout_width="@dimen/qr_placeholder_corner_size"
                    android:layout_height="@dimen/qr_placeholder_corner_size"
                    android:layout_gravity="start|top"
                    android:background="@drawable/bg_qr_corner">

                    <View
                        android:layout_width="@dimen/qr_placeholder_corner_inner_size"
                        android:layout_height="@dimen/qr_placeholder_corner_inner_size"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_qr_corner_inner" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/qr_placeholder_corner_size"
                    android:layout_height="@dimen/qr_placeholder_corner_size"
                    android:layout_gravity="end|top"
                    android:background="@drawable/bg_qr_corner">

                    <View
                        android:layout_width="@dimen/qr_placeholder_corner_inner_size"
                        android:layout_height="@dimen/qr_placeholder_corner_inner_size"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_qr_corner_inner" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="@dimen/qr_placeholder_corner_size"
                    android:layout_height="@dimen/qr_placeholder_corner_size"
                    android:layout_gravity="start|bottom"
                    android:background="@drawable/bg_qr_corner">

                    <View
                        android:layout_width="@dimen/qr_placeholder_corner_inner_size"
                        android:layout_height="@dimen/qr_placeholder_corner_inner_size"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_qr_corner_inner" />
                </FrameLayout>

                <TextView
                    style="@style/TextAppearance_ArtBarbershop_SectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/payment_qr_placeholder"
                    android:textColor="@color/color_text_primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/textPaymentCountdown"
                style="@style/TextAppearance_ArtBarbershop_Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_10"
                android:background="@drawable/bg_payment_amount_panel"
                android:textColor="@color/color_text_primary"
                tools:text="Payment expires in 14:48" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget_ArtBarbershop_Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:layout_marginBottom="@dimen/space_12"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/booking_row_icon_size"
                            android:layout_height="@dimen/booking_row_icon_size"
                            android:contentDescription="@string/payment_bank_information"
                            android:src="@drawable/ic_bank" />

                        <TextView
                            style="@style/TextAppearance_ArtBarbershop_Body"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            android:layout_weight="1"
                            android:text="@string/payment_bank_information"
                            android:textColor="@color/color_text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textPaymentBankName"
                        style="@style/TextAppearance_ArtBarbershop_Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:textColor="@color/color_text_primary"
                        tools:text="Bank Name        Art Barbershop Bank" />

                    <TextView
                        android:id="@+id/textPaymentAccountNumber"
                        style="@style/TextAppearance_ArtBarbershop_Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:textColor="@color/color_text_primary"
                        tools:text="Account Number   1234 5678 9012 3456" />

                    <TextView
                        android:id="@+id/textPaymentAccountName"
                        style="@style/TextAppearance_ArtBarbershop_Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:textColor="@color/color_text_primary"
                        tools:text="Account Name     Art Barbershop Co." />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/space_8"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textPaymentTransferContent"
                            style="@style/TextAppearance_ArtBarbershop_Body"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/color_text_primary"
                            tools:text="Transfer Content  INV2505251420" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/buttonCopyTransferContent"
                            style="@style/Widget_ArtBarbershop_SecondaryButton"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_height_small"
                            android:minHeight="@dimen/touch_target_min"
                            android:text="@string/action_copy"
                            android:textSize="@dimen/text_caption" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/paymentActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/color_surface"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/space_12"
        android:paddingEnd="@dimen/screen_horizontal_padding"
        android:paddingBottom="@dimen/space_12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonIHavePaid"
            style="@style/Widget_ArtBarbershop_PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/payment_action_paid" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonCheckStatus"
            style="@style/Widget_ArtBarbershop_SecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_8"
            android:text="@string/payment_action_check_status" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/booking_row_icon_size"
                android:layout_height="@dimen/booking_row_icon_size"
                android:contentDescription="@string/payment_security_note"
                android:src="@drawable/ic_shield" />

            <TextView
                style="@style/TextAppearance_ArtBarbershop_Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_6"
                android:text="@string/payment_security_note" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
