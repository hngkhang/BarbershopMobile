<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/reviewRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:fitsSystemWindows="true"
    tools:context=".util.ReviewActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reviewTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/screen_horizontal_padding"
        android:paddingTop="@dimen/space_16"
        android:paddingEnd="@dimen/screen_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/action_back"
            android:padding="@dimen/space_12"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textReviewTitle"
            style="@style/TextAppearance_ArtBarbershop_ScreenTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/screen_review_title"
            app:layout_constraintBottom_toBottomOf="@id/buttonBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/buttonBack"
            app:layout_constraintTop_toTopOf="@id/buttonBack" />

        <FrameLayout
            android:id="@+id/reviewTitleDivider"
            android:layout_width="@dimen/title_divider_width"
            android:layout_height="@dimen/space_12"
            app:layout_constraintEnd_toEndOf="@id/textReviewTitle"
            app:layout_constraintStart_toStartOf="@id/textReviewTitle"
            app:layout_constraintTop_toBottomOf="@id/textReviewTitle">

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/title_divider_height"
                android:layout_gravity="center"
                android:background="@color/color_accent_light" />

            <View
                android:layout_width="@dimen/title_divider_dot_size"
                android:layout_height="@dimen/title_divider_dot_size"
                android:layout_gravity="center"
                android:background="@drawable/bg_title_gold_divider" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/reviewScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="@dimen/screen_horizontal_padding"
        android:paddingEnd="@dimen/screen_horizontal_padding"
        android:paddingBottom="@dimen/space_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/reviewTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget_ArtBarbershop_Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_16">

                    <TextView
                        android:id="@+id/textReviewBarberInitial"
                        style="@style/TextAppearance_ArtBarbershop_CardTitle"
                        android:layout_width="@dimen/appointment_detail_avatar_size"
                        android:layout_height="@dimen/appointment_detail_avatar_size"
                        android:background="@drawable/bg_avatar_circle"
                        android:gravity="center"
                        android:textColor="@color/color_primary"
                        tools:text="M" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_12"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textReviewBarberName"
                            style="@style/TextAppearance_ArtBarbershop_CardTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="Michael" />

                        <TextView
                            android:id="@+id/textReviewService"
                            style="@style/TextAppearance_ArtBarbershop_Caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="Haircut, Classic Cut" />

                        <TextView
                            android:id="@+id/textReviewDate"
                            style="@style/TextAppearance_ArtBarbershop_Caption"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_4"
                            tools:text="Sat, May 24, 2025 at 11:00 AM" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/TextAppearance_ArtBarbershop_Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:text="@string/review_rate_barber"
                android:textColor="@color/color_text_primary"
                android:textStyle="bold" />

            <RatingBar
                android:id="@+id/ratingBarExperience"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_10"
                android:numStars="5"
                android:progressBackgroundTint="@color/color_border_strong"
                android:progressTint="@color/color_warning"
                android:secondaryProgressTint="@color/color_warning"
                android:stepSize="1"
                tools:rating="4" />

            <TextView
                android:id="@+id/textRatingLabel"
                style="@style/TextAppearance_ArtBarbershop_Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/review_rating_label_default"
                android:textColor="@color/color_primary"
                android:textStyle="bold" />

            <TextView
                style="@style/TextAppearance_ArtBarbershop_Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:text="@string/review_what_liked"
                android:textColor="@color/color_text_primary"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_10"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipFriendly"
                        style="@style/TextAppearance_ArtBarbershop_Caption"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target_min"
                        android:layout_marginEnd="@dimen/space_8"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/review_chip_friendly" />

                    <TextView
                        android:id="@+id/chipProfessional"
                        style="@style/TextAppearance_ArtBarbershop_Caption"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target_min"
                        android:layout_marginEnd="@dimen/space_8"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/review_chip_professional" />

                    <TextView
                        android:id="@+id/chipOnTime"
                        style="@style/TextAppearance_ArtBarbershop_Caption"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target_min"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/review_chip_on_time" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipGoodHaircut"
                        style="@style/TextAppearance_ArtBarbershop_Caption"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target_min"
                        android:layout_marginEnd="@dimen/space_8"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/review_chip_good_haircut" />

                    <TextView
                        android:id="@+id/chipCleanShop"
                        style="@style/TextAppearance_ArtBarbershop_Caption"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target_min"
                        android:layout_marginEnd="@dimen/space_8"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/review_chip_clean_shop" />

                    <TextView
                        android:id="@+id/chipGreatService"
                        style="@style/TextAppearance_ArtBarbershop_Caption"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/touch_target_min"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/review_chip_great_service" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/TextAppearance_ArtBarbershop_Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:text="@string/review_write_review"
                android:textColor="@color/color_text_primary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTextReview"
                style="@style/TextAppearance_ArtBarbershop_Body"
                android:layout_width="match_parent"
                android:layout_height="@dimen/review_text_area_height"
                android:layout_marginTop="@dimen/space_8"
                android:background="@drawable/bg_review_text_area"
                android:gravity="top|start"
                android:hint="@string/review_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLength="300"
                android:padding="@dimen/space_12"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_muted" />

            <TextView
                android:id="@+id/textReviewCounter"
                style="@style/TextAppearance_ArtBarbershop_Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="@string/review_character_counter_zero"
                tools:text="0/300" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonSubmitReview"
                style="@style/Widget_ArtBarbershop_PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/space_16"
                android:text="@string/review_submit" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/booking_row_icon_size"
                    android:layout_height="@dimen/booking_row_icon_size"
                    android:contentDescription="@string/review_trust_note"
                    android:src="@drawable/ic_lock" />

                <TextView
                    style="@style/TextAppearance_ArtBarbershop_Caption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:layout_weight="1"
                    android:text="@string/review_trust_note" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
